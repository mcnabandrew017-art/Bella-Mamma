{
  "name": "bella-mamma-pizza",
  "version": "1.0.0",
  "description": "Bella Mamma Pizza Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.bellamamma.pizza",
    "productName": "Bella Mamma Pizza",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "bella-mamma.html",
      "bella-mamma-backend/**/*"
    ],
    "extraResources": [
      {
        "from": "bella-mamma-backend",
        "to": "bella-mamma-backend"
      }
    ]
  },
  "dependencies": {
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  }
}